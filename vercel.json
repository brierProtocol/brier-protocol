{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "regions": [
    "lhr1"
  ],
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/score",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/cron/resolve-and-score",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/circuit-breaker",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/anchor-commitments",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/snapshot-equity",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
