{
  "name": "@brier/sdk",
  "version": "0.1.0",
  "description": "Connect a prediction bot to Brier Protocol in ~10 lines.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "brier",
    "prediction-markets",
    "polymarket",
    "trading-bot",
    "sdk"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
