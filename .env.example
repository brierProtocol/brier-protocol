# ─────────────────────────────────────────────────────────────
# Brier Protocol — environment template. Copy to .env.local and fill in.
# Do NOT commit real secrets.  [REQUIRED] = validated by src/lib/env.ts
# ─────────────────────────────────────────────────────────────

# ── Database (Postgres / Supabase) ──────────────────────────
# DATABASE_URL: pooled (pgbouncer) connection — used by the app at runtime.
# DIRECT_URL:   direct connection (port 5432) — used by `prisma migrate`.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"   # [REQUIRED]
DIRECT_URL="postgresql://user:password@host:5432/postgres"                    # [REQUIRED]

# ── App security ────────────────────────────────────────────
# 32-byte hex string. AES-256-GCM key for encrypting stored API credentials
# (PolyConnection / KalshiConnection). See src/lib/crypto.ts.
ENCRYPTION_SECRET=""                                                          # [REQUIRED]
# Shared secret protecting /api/cron/* (score, settle, status, sync).
CRON_SECRET="change-me-to-a-long-random-string"                              # [REQUIRED]
# Distributed rate-limit (middleware.ts). Optional — falls back to an in-memory
# per-instance Map if unset (which does NOT work across serverless lambdas).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Web3 frontend (wallet auth) ─────────────────────────────
# WalletConnect Cloud project id — read by src/lib/wagmi.ts (the live RainbowKit config).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""                                       # [REQUIRED]

# ── Vaults / on-chain reads (frontend) ──────────────────────
# Active EVM chain the wallet + vaults target. 80002 = Polygon Amoy (testnet, default),
# 137 = Polygon mainnet (prod, where Polymarket + real USDC live). When set to 137,
# also set NEXT_PUBLIC_DEPOSIT_RPC_URL and NEXT_PUBLIC_USDC_ADDRESS to mainnet values.
NEXT_PUBLIC_CHAIN_ID="80002"
# USDC contract on the target chain. SET THIS to reject fake-token deposits.
NEXT_PUBLIC_USDC_ADDRESS=""
NEXT_PUBLIC_VAULT_FACTORY_ADDRESS=""
NEXT_PUBLIC_AMOY_RPC_URL="https://rpc-amoy.polygon.technology"
NEXT_PUBLIC_DEPOSIT_RPC_URL="https://rpc-amoy.polygon.technology"

# ── Contract deploy / server-side vault ops (scripts, route handlers) ──
DEPLOY_RPC_URL="https://rpc-amoy.polygon.technology"
DEPLOYER_PRIVATE_KEY=""           # deploys contracts — keep secret
EXECUTOR_PRIVATE_KEY=""           # wallet key that signs vault calls — keep secret
EXECUTOR_ADDRESS=""
VAULT_FACTORY_ADDRESS=""
FEE_RECIPIENT_ADDRESS=""          # protocol fee recipient (10%)
GNOSIS_SAFE_ADMIN=""              # multisig admin for upgrades

# ── Bot signal ingest (app ← bots) ──────────────────────────
BUILDER_SECRET_KEY="64-char-hex-hmac-secret"   # HMAC secret for signed signals
BOT_INGEST_KEY=""

# ── Polymarket ──────────────────────────────────────────────
POLYMARKET_DATA_API="https://data-api.polymarket.com"
POLYMARKET_CTF_EXCHANGE=""

# ─────────────────────────────────────────────────────────────
# Executor service (brier-executor/) — runs as a separate process.
# ─────────────────────────────────────────────────────────────
BRIER_APP_URL="http://localhost:3000"
RPC_URL="https://rpc-amoy.polygon.technology"
POLYMARKET_CLOB_URL="https://clob.polymarket.com"
POLYMARKET_CHAIN_ID="137"
EXECUTOR_ALLOWED_IPS=""           # comma-separated allowlist
LOG_LEVEL="info"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""
