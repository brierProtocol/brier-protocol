# ─────────────────────────────────────────────────────────────
# Brier Protocol — environment template. Copy to .env.local and fill in.
# Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────

# Database (Postgres / Supabase)
DATABASE_URL="postgresql://user:password@host:port/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/postgres"

# Deposit verification (chain where the vaults live)
NEXT_PUBLIC_DEPOSIT_RPC_URL="https://rpc-amoy.polygon.technology"
# USDC contract address on the target chain. SET THIS to reject fake-token deposits.
NEXT_PUBLIC_USDC_ADDRESS=""

# Cron jobs (/api/cron/*)
CRON_SECRET="change-me-to-a-long-random-string"

# ── Executor service (brier-executor/) ──
BUILDER_SECRET_KEY="64-char-hex-hmac-secret"
EXECUTOR_PRIVATE_KEY=""        # wallet key that signs vault calls — keep secret
RPC_URL="https://rpc-amoy.polygon.technology"
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
